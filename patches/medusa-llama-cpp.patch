+// ============================================================================
+// Medusa speculative decoding API (BitNet + Medusa by Parrish Corcoran)
+// ============================================================================
+
+int32_t llama_n_medusa_heads(const struct llama_model * model) {
+    return model ? model->n_medusa_heads : 0;
+}
+
+int32_t llama_n_medusa_layers(const struct llama_model * model) {
+    return model ? model->n_medusa_layers_per_head : 0;
+}
+
+float * llama_get_medusa_logits_ith(struct llama_context * ctx, int32_t k, int32_t i) {
+    if (ctx == nullptr) return nullptr;
+    if (k < 0 || k >= ctx->model.n_medusa_heads)            return nullptr;
+    if ((int) ctx->medusa_logits.size() <= k)               return nullptr;
+    if (ctx->medusa_logits[k].empty())                      return nullptr;
+
+    llama_synchronize(ctx);
+
+    int32_t j = -1;
+    if (i < 0) {
+        j = ctx->n_outputs + i;
+        if (j < 0) return nullptr;
+    } else if ((size_t) i >= ctx->output_ids.size()) {
+        return nullptr;
+    } else {
+        j = ctx->output_ids[i];
+    }
+    if (j < 0 || j >= ctx->n_outputs) return nullptr;
+
+    const int64_t n_vocab = ctx->model.hparams.n_vocab;
+    if ((size_t)(j + 1) * n_vocab > ctx->medusa_logits[k].size()) return nullptr;
+    return ctx->medusa_logits[k].data() + (size_t) j * n_vocab;
+}
+
+void llama_set_tree_attention(struct llama_context * ctx, const struct llama_medusa_tree * tree) {
+    if (ctx == nullptr) return;
+    ctx->medusa_tree = tree;
+}
