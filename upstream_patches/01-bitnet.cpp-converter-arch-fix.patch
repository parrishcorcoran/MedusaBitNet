+    @staticmethod
+    def _unpack_ternary(packed: Tensor) -> Tensor:
+        """Unpack uint8-packed ternary weights to float32 {-1, 0, 1}.
+
+        Matches transformers.integrations.bitnet.unpack_weights exactly:
+        - Pack format: {-1,0,1} + 1 -> {0,1,2}, 4 values per byte, row-major.
+        - Unpack: extract 2-bit pairs, subtract 1.
+        - Row interleaving: bits [0:2] -> rows [0:R], bits [2:4] -> rows [R:2R], etc.
+        """
+        R = packed.shape[0]
+        unpacked = torch.zeros((R * 4, *packed.shape[1:]), dtype=torch.uint8, device=packed.device)
+        for i in range(4):
+            mask = 3 << (2 * i)
+            unpacked[i * R : (i + 1) * R] = (packed & mask) >> (2 * i)
+        return unpacked.float() - 1.0
+
